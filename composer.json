{
	"name": "phpgt/cipher",
	"description": "Two-way encryption of messages for secure plain text transmission.",
	"type": "library",
	"require": {
		"php": ">=8.4",
		"ext-sodium": "*",
		"phpgt/http": "^1.3"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^10.5 || ^12.0",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7 || ^4.0"
	},
	"autoload": {
		"psr-4": {
			"GT\\Cipher\\": "./src",
			"Gt\\Cipher\\": "./src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"GT\\Cipher\\Test\\": "./test/phpunit"
		}
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"authors": [
		{
			"name": "Greg Bowler",
			"homepage": "https://www.g105b.com",
			"email": "greg.bowler@g105b.com",
			"role": "Developer"
		}
	],

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
